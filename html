  .serif-h em{font-style:italic;color:var(--purple)}
  .body-copy{font-size:13px;color:var(--muted);line-height:1.85}
  .btn-dark{background:var(--ink);color:var(--ivory);padding:13px 30px;font-size:11px;letter-spacing:2px;text-transform:uppercase;border:none;cursor:pointer;font-family:var(--sans);transition:background .2s;text-decoration:none;display:inline-block}
