  .coach-card{display:flex;flex-direction:column}
  .coach-img{width:100%;aspect-ratio:3/4;object-fit:cover;background:var(--border)}
  .coach-img-placeholder{width:100%;aspect-ratio:3/4;background:linear-gradient(135deg,var(--warm),var(--border));display:flex;align-items:center;justify-content:center;font-family:var(--serif);font-size:64px;color:var(--hint)}
  .coach-tags{display:flex;flex-wrap:wrap;gap:6px;margin:1rem 0 .75rem}
  .coach-tag{font-size:9px;letter-spacing:2px;text-transform:uppercase;color:var(--orange);border:0.5px solid var(--orange);padding:3px 8px}
  .coach-name{font-family:var(--serif);font-size:26px;font-weight:400;color:var(--ink);margin-bottom:4px}
  .coach-title-txt{font-size:11px;letter-spacing:1px;text-transform:uppercase;color:var(--hint);margin-bottom:1rem}
  .coach-bio{font-size:13px;color:var(--muted);line-height:1.75}
  .coach-creds{display:flex;flex-wrap:wrap;gap:6px;margin-top:1rem}
  .coach-cred{font-size:10px;letter-spacing:1px;text-transform:uppercase;color:var(--purple);background:var(--warm);padding:4px 10px}

  /* WHY US */
  .why-dark{background:var(--ink)}
  .why-dark .inner{display:grid;grid-template-columns:1fr 1fr;gap:5rem;align-items:start}
  .why-dark .eyebrow{color:#4a2a6a}
  .why-dark .serif-h{color:var(--ivory)}
  .why-dark .serif-h em{color:var(--orange)}
  .why-items{display:flex;flex-direction:column;gap:0;margin-top:2rem}
  .why-item{border-top:0.5px solid #2a1a3a;padding:1.5rem 0}
  .why-item:last-child{border-bottom:0.5px solid #2a1a3a}
  .why-num{font-family:var(--serif);font-size:36px;font-weight:300;color:#2a1a3a;line-height:1;margin-bottom:6px}
  .why-title{font-size:14px;font-weight:500;color:var(--ivory);margin-bottom:6px;letter-spacing:.5px}
  .why-body{font-size:13px;color:#6a4a7a;line-height:1.75}

  /* CTA */
  .cta-section{background:var(--orange);padding:5rem 3rem;text-align:center}
  .cta-section h2{font-family:var(--serif);font-size:48px;font-weight:300;color:#fff;margin-bottom:1rem}
  .cta-section p{font-size:14px;color:rgba(255,255,255,.8);max-width:500px;margin:0 auto 2rem;line-height:1.75}
  .btn-white{background:#fff;color:var(--orange);padding:13px 30px;font-size:11px;letter-spacing:2px;text-transform:uppercase;border:none;cursor:pointer;font-family:var(--sans);font-weight:500;text-decoration:none;display:inline-block;transition:background .2s}
  .btn-white:hover{background:#f5eeff;color:var(--purple)}

  footer{background:#130620}
  .footer-inner{max-width:1200px;margin:0 auto;padding:4rem 3rem 2rem;display:grid;grid-template-columns:1.6fr 1fr 1fr 1fr;gap:3rem}
  .footer-brand{font-family:var(--serif);font-size:24px;font-weight:400;letter-spacing:3px;text-transform:uppercase;color:var(--ivory);display:block;margin-bottom:10px}
  .footer-tagline{font-size:12px;color:#4a2a5a;line-height:1.75}
  .footer-col h4{font-size:9px;letter-spacing:3px;text-transform:uppercase;color:#3a1a4a;margin-bottom:14px}
